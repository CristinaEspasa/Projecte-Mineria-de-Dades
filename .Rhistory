# Calcular la suma del valor absolut de les integrals de f(x) a [x_i, x_{i+1}].
f_original <- function(x) exp(-x/4) * cos(5 * x)
# Valor exacte: suma de |integral en cada tram|
suma_exacte <- 0
for (i in 1:(length(zeros)-1)) {
integral_tram <- abs(integrate(f_original, zeros[i], zeros[i+1])$value)
suma_exacte <- suma_exacte + integral_tram
}
# Aplicar mètodes numèrics per trams
suma_riemann <- 0
suma_trapezis <- 0
suma_simpson <- 0
for (i in 1:(length(zeros)-1)) {
# Crear malla per aquest tram (100 subintervals per tram)
n_tram <- 100
x_tram <- seq(zeros[i], zeros[i+1], length.out = n_tram + 1)
y_tram <- abs(f_original(x_tram))
suma_riemann <- suma_riemann + integ_riemann_midpoint(x_tram, y_tram)
suma_trapezis <- suma_trapezis + integ_trapezis(x_tram, y_tram)
suma_simpson <- suma_simpson + integ_simpson(x_tram, y_tram)
}
# Taula de resultats
resultats3 <- data.frame(
Metode = c("Rectangles (punt mig)", "Trapezis", "Simpson", "Valor exacte"),
Integral = c(suma_riemann, suma_trapezis, suma_simpson, suma_exacte),
Error_Absolut = c(abs(suma_riemann - suma_exacte), abs(suma_trapezis - suma_exacte),
abs(suma_simpson - suma_exacte), 0)
)
print(resultats3, digits = 16)
