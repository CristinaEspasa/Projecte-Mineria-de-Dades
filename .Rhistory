zeros <- c(0)  # Límit inferior
k <- 0
repeat {
zero_k <- pi/10 + k * pi/5
if (zero_k >= b) break
zeros <- c(zeros, zero_k)
k <- k + 1
}
zeros <- c(zeros, 5)  # Límit superior
