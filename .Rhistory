# Llegir les dades
df <- read.csv("irradiancia_panel_20x10.csv")
# Calcular Potència radiant (suma Riemann 2D)
# Malla de 20x10 sobre panell de 2.0 m x 1.0 m
# Centres de cel·la separats 0.1 m
# Àrea de cada cel·la: deltaA = 0.1 * 0.1 = 0.01 m²
deltaA <- 0.1 * 0.1
# Potència radiant total: P_rad = sum(E_ij * deltaA)
P_rad <- sum(df$irradiance_W_m2) * deltaA
cat("Potencia radiant total:", P_rad, "W\n")
# Calcular Potència elèctrica
eta <- 0.18  # Eficiència 18%
P_elec <- eta * P_rad
cat("Potencia electrica (eta = 18%):", P_elec, "W\n")
# Comparar amb el Cas ideal
# Panell: 2.0 m x 1.0 m = 2.0 m²
# Irradiància uniforme: 850 W/m²
Area_total <- 2.0 * 1.0
E_ideal <- 850
P_rad_ideal <- E_ideal * Area_total
P_elec_ideal <- eta * P_rad_ideal
cat("\n--- CAS IDEAL ---\n")
cat("Potencia radiant ideal:", P_rad_ideal, "W\n")
cat("Potencia electrica ideal (eta = 18%):", P_elec_ideal, "W\n")
cat("\n--- COMPARACIO ---\n")
percentatge <- 100 * P_elec / P_elec_ideal
perdua <- 100 * (1 - P_elec / P_elec_ideal)
cat("Percentatge respecte al cas ideal:", round(percentatge, 2), "%\n")
cat("Perdua deguda a l'ombrejat:", round(perdua, 2), "%\n")
