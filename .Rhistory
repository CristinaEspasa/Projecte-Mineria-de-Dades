####### Funcions auxiliars #######
# Funció per a la lectura de dades
myReadData_byDate = function(file, column){
df = read.csv(file, sep = ',', header = TRUE, row.names = NULL)
return(na.omit(df[,c('Year_Month', column)]) )
}
## Funció que resol el sistema d'equacions normals mitjançant l'expressió (5) de la guia
mylssolve = function(A, b){
AT = t(A)
return(solve(AT %*% A, AT %*% b))
}
# Funció que avalua un ajust definit pels coeficients "c" en els punts "x" (que pot ser un vector de punts)
myeval = function(x, c){
f = 0
for (i in 1:length(c)) {
f = f + c[i] * x^(i-1)
}
return(f)
}
####### Exercici 1 #######
### Lectura de dades ###
# En 'Y' emmagatzemem els valors d'HICP i en 't' els mesos
Y = myReadData_byDate('20251-OECD_SPAIN_UNEMPLOYMENT_EUROSTAT_PRICEINDEXGROWTH.csv',
c('HICP_Y2Y_GROWTH_RATE','UNEMPLOYMENT'))
# Taxa d'inflació
pi_t = Y$HICP_Y2Y_GROWTH_RATE
# Taxa d'atur
u_t = Y$UNEMPLOYMENT
# Matriu de disseny per a regressió lineal simple: pi_t = c0 + c1*u_t
# Phi té dimensions m x 2, on m és el nombre d'observacions
m = length(pi_t)
Phi = matrix(1, m, 2)
Phi[, 1] = 1  # Terme independent
Phi[, 2] = u_t  # Variable independent
c = mylssolve(Phi, pi_t)
cat("Exercici 1 - coeficients:", c, "\n")
# Gràfica
plot(u_t, pi_t,
xlab = 'Taxa d\'atur',
ylab = 'Taxa d\'inflació',
main = 'Corba de Phillips (exercici 1)',
pch = 16, col = 'blue')
# Ordenem u_t per fer la línia correctament
ordre = order(u_t)
lines(u_t[ordre], myeval(u_t[ordre], c), col='red', lwd=3)
# Coeficient de determinació
pi_t_pred = myeval(u_t, c)
SSR = sum((pi_t - pi_t_pred)^2)
SST = sum((pi_t - mean(pi_t))^2)
r2 = 1 - SSR/SST
cat("Exercici 1 - Coeficient de determinació:", r2, "\n")
# Taxa natural d'atur
# pi_t = pi_e_t - alpha*(u_t - u_n)
# Amb pi_e_t = pi_bar = 2%
# pi_t = pi_bar - alpha*u_t + alpha*u_n
# pi_t = (pi_bar + alpha*u_n) - alpha*u_t
# c[1] = pi_bar + alpha*u_n, c[2] = -alpha
# u_n = (c[1] - pi_bar) / alpha = (c[1] - 2) / (-c[2])
pi_bar = 2
u_n = (c[1] - pi_bar) / (-c[2])
cat("Exercici 1 - Taxa natural d'atur:", u_n, "\n")
# Taxa d'inflació (sense els primers 12 mesos)
pi_t2 = pi_t[13:length(pi_t)]
# Taxa d'inflació del període anterior (-12)
pi_t_prev = pi_t[1:(length(pi_t)-12)]
# Taxa d'atur (sense els primers 12 mesos)
u_t2 = u_t[13:length(u_t)]
m2 = length(pi_t2)
# Matriu de disseny per a regressió multineal
# pi_t = c0 + c1*pi_{t-12} + c2*u_t
# Nota: segons la formulació pi_t = pi_e_t - alpha*(u_t - u_n)
# amb pi_e_t = (1-theta)*pi_{t-12} + theta*pi_bar
# pi_t = (1-theta)*pi_{t-12} + theta*pi_bar - alpha*u_t + alpha*u_n
# pi_t = c0 + c1*pi_{t-12} + c2*u_t
# on c0 = theta*pi_bar + alpha*u_n, c1 = 1-theta, c2 = -alpha
Phi2 = matrix(1, m2, 3)
Phi2[, 1] = 1  # Terme independent
Phi2[, 2] = pi_t_prev  # pi_{t-12}
Phi2[, 3] = u_t2  # Taxa d'atur
c2 = mylssolve(Phi2, pi_t2)
cat("Exercici 2 - coeficients:", c2, "\n")
# Residus
pi_t2_pred = Phi2 %*% c2
residus = pi_t2 - pi_t2_pred
plot(1:m2, residus,
xlab = 'període t',
ylab = 'Residu',
main = 'Exercici 2 - Residus del model',
pch = 16, col = 'blue')
abline(h = 0, col = 'red', lwd = 2, lty = 2)
# Coeficient de determinació
SSR2 = sum(residus^2)
SST2 = sum((pi_t2 - mean(pi_t2))^2)
r22 = 1 - SSR2/SST2
cat("Exercici 2 - Coeficient de determinació:", r22, "\n")
# theta
# c1 = 1 - theta => theta = 1 - c1
theta = 1 - c2[2]
cat("Exercici 2 - Theta:", theta, "\n")
# Taxa natural d'atur
# c0 = theta*pi_bar + alpha*u_n, c2 = -alpha
# u_n = (c0 - theta*pi_bar) / alpha = (c0 - theta*pi_bar) / (-c2)
u_n2 = (c2[1] - theta * pi_bar) / (-c2[3])
cat("Exercici 2 - Taxa natural d'atur:", u_n2, "\n")
# Comprovació amb lm (opcional, per verificar)
cat("\n--- Comprovació amb lm ---\n")
cat("Exercici 1:\n")
model1 = lm(pi_t ~ u_t)
print(summary(model1))
cat("\nExercici 2:\n")
model2 = lm(pi_t2 ~ pi_t_prev + u_t2)
print(summary(model2))
