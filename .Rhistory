f <- function(x) exp(-x/4) * cos(5 * x)
a <- 0; b <- 5
n <- 100                  # parell per a Simpson 1/3
h <- (b - a) / n
x <- seq(a, b, length.out = n + 1)
y <- f(x)
# --- Rectangles: punt mig ---
I_riemann <- integ_riemann_midpoint(x, y)
# --- Trapezis compost ---
I_trapezis <- integ_trapezis(x, y)
# --- Simpson compost ---
I_simpson <- integ_simpson(x, y)
# --- Valor de referència amb integrate() ---
I_exact <- integrate(f, a, b)$value
# --- Taula de Resultats ---
cat("\n=== INTEGRACIO DE f(x) = exp(-x/4) * cos(5x) ===\n\n")
resultats1 <- data.frame(
Metode = c("Rectangles (punt mig)", "Trapezis", "Simpson", "Valor exacte"),
Integral = c(I_riemann, I_trapezis, I_simpson, I_exact),
Error_Absolut = c(abs(I_riemann - I_exact), abs(I_trapezis - I_exact),
abs(I_simpson - I_exact), 0)
)
print(resultats1, digits = 16)
