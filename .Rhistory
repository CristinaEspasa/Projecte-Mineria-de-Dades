# Matriu d'enllaços L (files: destinació, columnes: origen)
L <- matrix(c(
0, 0, 1, 1,  # Pàgina 1 rep de 3 i 4
1, 0, 0, 0,  # Pàgina 2 rep d'1
1, 1, 0, 1,  # Pàgina 3 rep de 1, 2 i 4
1, 1, 0, 0   # Pàgina 4 rep d'1 i 2
), nrow = 4, byrow = TRUE)
# Construcció de la matriu de transició A
A <- matrix(0, 4, 4)
for (j in 1:4) {
col_sum <- sum(L[, j])
if (col_sum > 0) {
A[, j] <- L[, j] / col_sum
}
}
# Vector de personalització uniforme
v <- rep(1/4, 4)
# Valors de d a analitzar
d_vals <- c(0.65, 0.85, 0.95)
# Funció per a resoldre el sistema (I - dA)x = (1 - d)v
resolver_pagerank <- function(d, A, v) {
I <- diag(4)
b <- (1 - d) * v
x <- solve(I - d * A, b)
return(x / sum(x))  # Normalització
}
# Calcular PageRank per a cada d
resultados <- sapply(d_vals, function(d) resolver_pagerank(d, A, v))
colnames(resultados) <- paste0("d=", d_vals)
rownames(resultados) <- paste0("Pàgina ", 1:4)
print(resultados)
matplot(d_vals, t(resultados), type = "b", pch = 19, col = 1:4,
xlab = "Factor d'esmorteïment (d)",
ylab = "PageRank",
main = "Evolució del PageRank en funció de d")
legend("right", legend = paste0("Pàgina ", 1:4),
col = 1:4, pch = 19, lty = 1:4)
# Afegir un enllaç de la pàgina 2 a la pàgina 1
L_mod <- L
L_mod[1, 2] <- 1   # Pàgina 2 ara també enllaça a la pàgina 1
# Recalcular la matriu de transició A_mod
A_mod <- matrix(0, 4, 4)
for (j in 1:4) {
col_sum <- sum(L_mod[, j])
if (col_sum > 0) {
A_mod[, j] <- L_mod[, j] / col_sum
}
}
# Vector de personalització uniforme
v <- rep(1/4, 4)
# Factor d'esmorteïment
d <- d <- 0.85
# Resolució del sistema (I - dA)x = (1 - d)v
I <- diag(4)
b <- (1 - d) * v
x_mod <- solve(I - d * A_mod, b)
x_mod <- x_mod / sum(x_mod) # Normalització
# Mostrar resultats
names(x_mod) <- paste0("Pàgina ", 1:4)
print("PageRank amb xarxa modificada:")
