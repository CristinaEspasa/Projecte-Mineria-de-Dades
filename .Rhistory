# Vector de personalització
v <- rep(1/4, 4)
# Mètode de la potència
metodo_potencia <- function(A, d, v, tol = 1e-6, max_iter = 1000) {
x <- rep(1/4, 4)  # Vector inicial
for (k in 1:max_iter) {
x_new <- d * A %*% x + (1 - d) * v
if (max(abs(x_new - x)) < tol) {
return(list(x = x_new / sum(x_new), iteracions = k))
}
x <- x_new
}
return(list(x = x / sum(x), iteracions = max_iter))
}
# Executar per a diferents valors de d
d_vals <- c(0.65, 0.85, 0.95)
for (d in d_vals) {
resultado <- metodo_potencia(A, d, v)
cat("\nResultats per a d =", d, "\n")
cat("Nombre d'iteracions:", resultado$iteracions, "\n")
print(resultado$x)
}
# --- Rectangles: punt mig --- (implementar funci?)
integ_riemann_midpoint <- function(x, y) {
n <- length(x) - 1
h <- (x[length(x)] - x[1]) / n
}
# --- Rectangles: punt mig --- (implementar funci?)
integ_riemann_midpoint <- function(x, y) {
n <- length(x) - 1
h <- (x[length(x)] - x[1]) / n
# Punts mitjos entre cada parella de punts consecutius
x_mid <- (x[1:n] + x[2:(n+1)]) / 2
y_mid <- (y[1:n] + y[2:(n+1)]) / 2
# Suma de Riemann amb punts mitjos
integral <- sum(y_mid) * h
return(integral)
}
# --- Trapezis compost ---
integ_trapezis <- function(x, y) {
n <- length(x) - 1
h <- (x[length(x)] - x[1]) / n
# Fórmula dels trapezis: h * [f(x0)/2 + f(x1) + f(x2) + ... + f(xn-1) + f(xn)/2]
integral <- h * (y[1]/2 + sum(y[2:n]) + y[n+1]/2)
return(integral)
}
# --- Simpson compost ---
integ_simpson <- function(x, y) {
n <- length(x) - 1
# Comprovem que n sigui parell
if (n %% 2 != 0) {
stop("El nombre de subintervals ha de ser parell per Simpson")
}
h <- (x[length(x)] - x[1]) / n
# Fórmula de Simpson: (h/3) * [f(x0) + 4*f(x1) + 2*f(x2) + 4*f(x3) + ... + f(xn)]
suma_senars <- sum(y[seq(2, n, by = 2)])  # x1, x3, x5, ...
suma_parells <- sum(y[seq(3, n, by = 2)])  # x2, x4, x6, ...
integral <- (h/3) * (y[1] + 4*suma_senars + 2*suma_parells + y[n+1])
return(integral)
}
